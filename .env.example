# Copy: cp .env.example .env
# Prisma / PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/DBNAME?schema=public"

# NestJS (apps/api)
PORT=3000

# JWT (use a strong secret in production)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Redis (optional; API runs without it — example for Docker Compose)
# REDIS_URL=redis://localhost:6379

# Trust proxy for correct client IP behind a reverse proxy (rate limits): 1 = first hop, unset/false = off
# TRUST_PROXY=1

# HTTP response cache TTL (ms), default 30000
# HTTP_CACHE_TTL_MS=30000

# Global rate limit: window (ms) and max requests per IP per window
# THROTTLE_TTL_MS=60000
# THROTTLE_LIMIT=120
# Stricter cap for POST /auth/login (same window)
# THROTTLE_LOGIN_LIMIT=10
